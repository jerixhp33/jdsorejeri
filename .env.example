# ============================================================
# LUXE STORE — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# ─── Site ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── WhatsApp ───────────────────────────────────────────────
# Format: country code + number (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=919360490974

# ─── Google OAuth ───────────────────────────────────────────
# Configure in Supabase Dashboard → Authentication → Providers → Google
# Add your OAuth redirect URL: https://your-project.supabase.co/auth/v1/callback
# GOOGLE_CLIENT_ID=your_google_client_id (set in Supabase Dashboard)
# GOOGLE_CLIENT_SECRET=your_google_client_secret (set in Supabase Dashboard)

# ─── Email (required for Broadcast campaigns) ──────────────
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → create App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16char_app_password


# ─── Optional: Analytics ────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
